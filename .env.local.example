# ── Supabase (GitHub OAuth 인증 및 캐시 DB) ──────────────────────
# Supabase 프로젝트 설정 > API 탭에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── GitHub Personal Access Token ────────────────────────────────
# 퍼블릭 레포만 분석할 경우: read:user, repo 스코프 필요
# OAuth 로그인 사용자는 Supabase provider_token을 우선 사용하므로 선택사항
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── Anthropic API (Claude AI 로드맵 생성) ────────────────────────
# https://console.anthropic.com 에서 발급
# 미설정 시 하드코딩된 fallback 설명을 사용합니다
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
