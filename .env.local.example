# ── Supabase (GitHub OAuth 인증 및 캐시 DB) ──────────────────────
# Supabase 프로젝트 설정 > API 탭에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── GitHub Personal Access Token ────────────────────────────────
# 필요 스코프: read:user, repo (퍼블릭 레포 분석 + GitHub Models AI)
# OAuth 로그인 사용자는 Supabase provider_token을 우선 사용하므로 선택사항
# 이 토큰으로 GitHub API + GitHub Models AI(gpt-4o-mini) 모두 인증됩니다
# 무료 한도: 15 req/min, 별도 API 키 불필요
# GitHub Models: https://github.com/marketplace/models
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
